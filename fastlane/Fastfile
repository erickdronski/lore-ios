# Lore, cloud build to TestFlight (see CI-SETUP.md).
#
# Signing uses fastlane match (git storage) with the App Store Connect API key:
# match creates + stores an Apple Distribution certificate and App Store
# provisioning profiles for the app and the widget (encrypted in the lore-certs
# repo), and installs them into the CI keychain correctly. The project is then
# switched to MANUAL app-store signing so the archive uses those profiles.
#
# Secrets: ASC_KEY_ID / ASC_ISSUER_ID / ASC_KEY_CONTENT (the API key),
# MATCH_PASSWORD (decrypts the certs), MATCH_GIT_BASIC_AUTHORIZATION (repo auth).

default_platform(:ios)

BUNDLE_ID = "com.erickdronski.lore"
WIDGET_ID = "com.erickdronski.lore.LoreWidget"
TEAM_ID = "J9DMDH4S58"
CERTS_REPO = "https://github.com/erickdronski/lore-certs.git"

# Authenticate Spaceship (the ASC API client) from the same secrets the other
# lanes use. ASC_KEY_CONTENT is stored base64-encoded. Defined at the top level
# of the Fastfile so every lane can call it directly.
def asc_token!
  require "spaceship"
  require "base64"
  Spaceship::ConnectAPI.token = Spaceship::ConnectAPI::Token.create(
    key_id: ENV.fetch("ASC_KEY_ID"),
    issuer_id: ENV.fetch("ASC_ISSUER_ID"),
    key: Base64.decode64(ENV.fetch("ASC_KEY_CONTENT")),
  )
end

platform :ios do
  desc "Run the release unit-test gate on an iPhone simulator"
  lane :tests do
    run_tests(
      project: "Lore.xcodeproj",
      scheme: "Lore",
      devices: ["iPhone 16 Pro"],
      ensure_devices_found: true,
      clean: true,
      result_bundle: true,
      output_directory: "build/test-results",
    )
  end

  desc "Capture App Store screenshots on the Simulator (no signing needed)"
  lane :screenshots do
    # Reads fastlane/Snapfile: boots the 6.9" Simulator, runs the LoreUITests
    # capturer (LoreScreenshots.swift) against the LoreScreenshots scheme, and
    # writes PNGs to fastlane/screenshots. Never touches signing or TestFlight.
    capture_ios_screenshots
  end

  desc "Upload the App Store marketing screenshots via the ASC API (no binary)"
  lane :screenshots_upload do
    # Pure App Store Connect API upload of the pre-rendered marketing frames in
    # fastlane/promo_screenshots/en-US (1320x2868, the 6.9" slot that also fills
    # 6.7"/6.5"). skip_binary_upload + skip_metadata mean this touches ONLY the
    # screenshots on the editable version — never the build or the text metadata
    # (description/keywords stay exactly as set). Runs on Linux; no Xcode needed.
    source_sha_path = File.expand_path("promo_screenshots/SOURCE_SHA", __dir__)
    UI.user_error!(
      "Missing fastlane/promo_screenshots/SOURCE_SHA. Regenerate screenshots from the release commit before upload.",
    ) unless File.exist?(source_sha_path)

    screenshot_sha = File.read(source_sha_path).strip
    current_sha = sh("git rev-parse HEAD").strip
    UI.user_error!(
      "Screenshots were captured from #{screenshot_sha}, but the checkout is #{current_sha}. Regenerate them from this exact commit.",
    ) unless screenshot_sha == current_sha

    api_key = app_store_connect_api_key(
      key_id: ENV.fetch("ASC_KEY_ID"),
      issuer_id: ENV.fetch("ASC_ISSUER_ID"),
      key_content: ENV.fetch("ASC_KEY_CONTENT"),
      is_key_content_base64: true,
    )
    upload_to_app_store(
      api_key: api_key,
      app_identifier: BUNDLE_ID,
      skip_binary_upload: true,
      skip_metadata: true,
      skip_screenshots: false,
      screenshots_path: "./fastlane/promo_screenshots",
      overwrite_screenshots: true,
      run_precheck_before_submit: false,
      force: true,
    )
  end

  desc "READ-ONLY App Store submission preflight — reports the real ASC state"
  lane :preflight do
    # Pure GET calls. Changes nothing. Every section is individually rescued so
    # one unsupported endpoint cannot blind the rest of the audit. Findings are
    # prefixed PF| so they can be grepped straight out of the CI log.
    asc_token!
    say = ->(status, label, detail) { UI.message("PF|#{status}|#{label}|#{detail}") }

    app = Spaceship::ConnectAPI::App.find(BUNDLE_ID)
    if app.nil?
      say.call("FAIL", "App", "No app found for #{BUNDLE_ID}")
      next
    end
    say.call("INFO", "App", "#{app.name} (#{BUNDLE_ID}) id=#{app.id} locale=#{app.primary_locale}")

    # --- Editable version + attached build ---
    version = nil
    begin
      version = app.get_edit_app_store_version
      if version
        say.call("INFO", "Version", "#{version.version_string} state=#{version.app_store_state} release=#{version.release_type}")
      else
        say.call("WARN", "Version", "No editable version — nothing staged to submit")
      end
    rescue => e
      say.call("WARN", "Version", "lookup failed: #{e.message}")
    end

    begin
      b = version&.get_build
      if b
        say.call("PASS", "Build attached", "build #{b.version} state=#{b.processing_state}")
      else
        say.call("FAIL", "Build attached", "No build attached to the editable version")
      end
    rescue => e
      say.call("WARN", "Build attached", "lookup failed: #{e.message}")
    end

    begin
      builds = app.get_builds(limit: 5)
      builds.each do |bd|
        say.call("INFO", "TestFlight build", "#{bd.version} processing=#{bd.processing_state} expired=#{bd.expired}")
      end
    rescue => e
      say.call("WARN", "TestFlight builds", "lookup failed: #{e.message}")
    end

    # --- Store listing text ---
    begin
      version&.get_app_store_version_localizations&.each do |loc|
        desc_len = loc.description.to_s.length
        say.call(desc_len > 10 ? "PASS" : "FAIL", "Description (#{loc.locale})", "#{desc_len} chars")
        say.call(loc.keywords.to_s.empty? ? "FAIL" : "PASS", "Keywords (#{loc.locale})", loc.keywords.to_s)
        say.call(loc.support_url.to_s.empty? ? "FAIL" : "PASS", "Support URL", loc.support_url.to_s)
        say.call(loc.marketing_url.to_s.empty? ? "WARN" : "PASS", "Marketing URL", loc.marketing_url.to_s)
        say.call(loc.whats_new.to_s.empty? ? "WARN" : "PASS", "What's New", "#{loc.whats_new.to_s.length} chars")
        say.call(loc.promotional_text.to_s.empty? ? "WARN" : "PASS", "Promo text", "#{loc.promotional_text.to_s.length} chars")

        # Screenshots per device slot
        begin
          loc.get_app_screenshot_sets.each do |set|
            n = set.app_screenshots&.count.to_i
            say.call(n.zero? ? "FAIL" : "PASS", "Screenshots #{set.screenshot_display_type}", "#{n} image(s)")
          end
        rescue => e
          say.call("WARN", "Screenshots", "lookup failed: #{e.message}")
        end
      end
    rescue => e
      say.call("WARN", "Listing text", "lookup failed: #{e.message}")
    end

    # --- Privacy policy + age rating (live on AppInfo, not the version) ---
    begin
      app.get_app_infos.each do |info|
        begin
          info.get_app_info_localizations.each do |il|
            next if il.privacy_policy_url.to_s.empty? && il.locale != app.primary_locale
            say.call(il.privacy_policy_url.to_s.empty? ? "FAIL" : "PASS",
                     "Privacy policy URL (#{il.locale})", il.privacy_policy_url.to_s)
          end
        rescue => e
          say.call("WARN", "Privacy policy URL", "lookup failed: #{e.message}")
        end
        begin
          ard = info.get_age_rating_declaration
          say.call(ard.nil? ? "FAIL" : "PASS", "Age rating declaration", ard.nil? ? "missing" : "present")
        rescue => e
          say.call("WARN", "Age rating", "lookup failed: #{e.message}")
        end
      end
    rescue => e
      say.call("WARN", "AppInfo", "lookup failed: #{e.message}")
    end

    # --- Subscriptions (Lore+): each needs a review screenshot to be submittable ---
    begin
      groups = app.get_subscription_groups
      if groups.nil? || groups.empty?
        say.call("WARN", "Subscriptions", "No subscription groups returned")
      end
      groups&.each do |g|
        subs = begin
                 g.get_subscriptions
               rescue
                 nil
               end
        subs&.each do |s|
          say.call("INFO", "Subscription", "#{s.name} product=#{s.product_id} state=#{s.state}")
        end
      end
    rescue => e
      say.call("WARN", "Subscriptions", "lookup failed (may need UI check): #{e.message}")
    end

    # --- Already submitted? ---
    begin
      sub = version&.fetch_app_store_version_submission
      say.call(sub.nil? ? "INFO" : "WARN", "Existing submission",
               sub.nil? ? "none — version is not yet submitted" : "a submission already exists")
    rescue => e
      say.call("INFO", "Existing submission", "none detected (#{e.class})")
    end

    UI.important("PF|NOTE|Manual-only checks|EU trader status, Paid Applications Agreement and subscription REVIEW SCREENSHOTS are not reliably exposed by the ASC API — confirm in the App Store Connect UI.")
  end

  desc "Submit the editable App Store version for review (guarded)"
  lane :submit_for_review do
    asc_token!
    app = Spaceship::ConnectAPI::App.find(BUNDLE_ID)
    UI.user_error!("No app for #{BUNDLE_ID}") if app.nil?
    version = app.get_edit_app_store_version
    UI.user_error!("No editable version to submit") if version.nil?
    build = version.get_build
    UI.user_error!("Refusing to submit: no build attached to #{version.version_string}") if build.nil?

    UI.important("Submitting #{app.name} #{version.version_string} (build #{build.version}) for review…")
    version.create_app_store_version_submission
    UI.success("Submitted #{version.version_string} build #{build.version} for App Store review.")
  end

  desc "Build Lore and upload the build to TestFlight"
  lane :beta do
    # Local/manual invocations cannot bypass tests. CI sets LORE_TESTED=1 only
    # after the separate test step has passed for this exact checkout.
    tests unless ENV["LORE_TESTED"] == "1"

    # A clean, throwaway keychain on CI so codesign has somewhere to live.
    setup_ci

    api_key = app_store_connect_api_key(
      key_id: ENV.fetch("ASC_KEY_ID"),
      issuer_id: ENV.fetch("ASC_ISSUER_ID"),
      key_content: ENV.fetch("ASC_KEY_CONTENT"),
      is_key_content_base64: true,
    )

    # The App IDs (com.erickdronski.lore + .LoreWidget) are already registered
    # in the Developer portal, so there is no `produce` step: produce authenticates
    # with an Apple ID + password, not the App Store Connect API key, so it cannot
    # run headless here. match just needs the App IDs to exist, which they do.

    # Cert + App Store profiles for both bundle ids. readonly:false so the first
    # run creates and stores them; later runs just fetch and install.
    # force:true REGENERATES the profiles each run so a capability newly added to
    # the App ID (Sign in with Apple, 2026-07-16) is always reflected — a stale
    # stored profile would fail codesign with "provisioning profile doesn't
    # include the com.apple.developer.applesignin entitlement". The cert is
    # reused, not revoked.
    match(
      type: "appstore",
      api_key: api_key,
      app_identifier: [BUNDLE_ID, WIDGET_ID],
      git_url: CERTS_REPO,
      readonly: false,
      force: true,
    )

    # Force MANUAL app-store signing on the freshly generated project so the
    # archive uses the match profiles directly (no development profile, no
    # device requirement).
    update_code_signing_settings(
      path: "Lore.xcodeproj",
      use_automatic_signing: false,
      team_id: TEAM_ID,
      code_sign_identity: "Apple Distribution",
      targets: ["Lore"],
      profile_name: "match AppStore #{BUNDLE_ID}",
    )
    update_code_signing_settings(
      path: "Lore.xcodeproj",
      use_automatic_signing: false,
      team_id: TEAM_ID,
      code_sign_identity: "Apple Distribution",
      targets: ["LoreWidget"],
      profile_name: "match AppStore #{WIDGET_ID}",
    )

    # A monotonic CFBundleVersion: one above whatever TestFlight already has, so
    # a re-run never collides on the "must be higher than the previously
    # uploaded version" 409. Passing CURRENT_PROJECT_VERSION only as an xcarg did
    # NOT stick (the archive shipped as "1" every time), so write it into the
    # generated project with agvtool (needs VERSIONING_SYSTEM=apple-generic,
    # set in project.yml). Falls back to 0 when the app has no builds yet.
    app_version = get_version_number(
      xcodeproj: "Lore.xcodeproj",
      target: "Lore",
    )
    latest = latest_testflight_build_number(
      api_key: api_key,
      app_identifier: BUNDLE_ID,
      version: app_version,
      initial_build_number: 0,
    )
    build_number = latest.to_i + 1
    increment_build_number(
      xcodeproj: "Lore.xcodeproj",
      build_number: build_number,
    )

    build_app(
      project: "Lore.xcodeproj",
      scheme: "Lore",
      configuration: "Release",
      export_method: "app-store",
      xcargs: "CURRENT_PROJECT_VERSION=#{build_number}",
      output_directory: "build",
      clean: true,
      export_options: {
        method: "app-store",
        signingStyle: "manual",
        teamID: TEAM_ID,
        provisioningProfiles: {
          BUNDLE_ID => "match AppStore #{BUNDLE_ID}",
          WIDGET_ID => "match AppStore #{WIDGET_ID}",
        },
      },
    )

    upload_to_testflight(
      api_key: api_key,
      app_identifier: BUNDLE_ID,
      # Do not block the runner waiting for Apple to finish processing; the
      # build shows up in TestFlight a few minutes later.
      skip_waiting_for_build_processing: true,
    )
  end
end
