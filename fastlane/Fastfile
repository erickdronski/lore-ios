# Lore, cloud build to TestFlight (see CI-SETUP.md).
#
# Signing: the App Store Connect API key creates an Apple Distribution
# certificate (cert) and App Store provisioning profiles (sigh) for the app and
# the widget, then the generated project is switched to MANUAL app-store signing
# so the archive never asks for a development profile (which would need
# registered devices). No fastlane match, no certs repo. Secrets are only the
# three ASC_* API-key values.

default_platform(:ios)

BUNDLE_ID = "app.lore.lore"
WIDGET_ID = "app.lore.lore.LoreWidget"
TEAM_ID = "J9DMDH4S58"

platform :ios do
  desc "Build Lore and upload the build to TestFlight"
  lane :beta do
    # A clean, throwaway keychain on CI so codesign has somewhere to live.
    setup_ci

    api_key = app_store_connect_api_key(
      key_id: ENV.fetch("ASC_KEY_ID"),
      issuer_id: ENV.fetch("ASC_ISSUER_ID"),
      key_content: ENV.fetch("ASC_KEY_CONTENT"),
      is_key_content_base64: true,
    )

    # An Apple Distribution certificate into the CI keychain (reuses one from
    # the account if its key is present, else creates it via the API key).
    cert(api_key: api_key)

    # App Store profiles for both bundle ids (registers the App IDs if missing).
    app_profile = sigh(api_key: api_key, app_identifier: BUNDLE_ID)
    widget_profile = sigh(api_key: api_key, app_identifier: WIDGET_ID)

    # Force MANUAL app-store signing on the freshly generated project so the
    # archive uses the distribution profiles directly, no dev profile, no
    # device requirement.
    update_code_signing_settings(
      path: "Lore.xcodeproj",
      use_automatic_signing: false,
      team_id: TEAM_ID,
      code_sign_identity: "Apple Distribution",
      targets: ["Lore"],
      profile_name: app_profile,
    )
    update_code_signing_settings(
      path: "Lore.xcodeproj",
      use_automatic_signing: false,
      team_id: TEAM_ID,
      code_sign_identity: "Apple Distribution",
      targets: ["LoreWidget"],
      profile_name: widget_profile,
    )

    # A monotonic build number per CI run so TestFlight never rejects a
    # duplicate. Falls back to 1 for a local run.
    build_number = ENV["GITHUB_RUN_NUMBER"] || "1"

    build_app(
      project: "Lore.xcodeproj",
      scheme: "Lore",
      configuration: "Release",
      export_method: "app-store",
      xcargs: "CURRENT_PROJECT_VERSION=#{build_number}",
      output_directory: "build",
      clean: true,
      export_options: {
        method: "app-store",
        signingStyle: "manual",
        teamID: TEAM_ID,
        provisioningProfiles: {
          BUNDLE_ID => app_profile,
          WIDGET_ID => widget_profile,
        },
      },
    )

    upload_to_testflight(
      api_key: api_key,
      app_identifier: BUNDLE_ID,
      # Do not block the runner waiting for Apple to finish processing; the
      # build shows up in TestFlight a few minutes later.
      skip_waiting_for_build_processing: true,
    )
  end
end
