# fastlane snapshot config for Lore's App Store screenshots.
#
# Runs on the Simulator (no code signing). Captures the non-camera surfaces at
# the 6.9" size, which App Store Connect now requires and can down-scale to the
# 6.5" slot, so one device covers both iPhone requirements.
#
# Regenerate any time: `bundle exec fastlane screenshots`.

devices([
  "iPhone 16 Pro Max"
])

languages([
  "en-US"
])

# The scheme wired for testing in project.yml (its Test action runs LoreUITests).
scheme("LoreScreenshots")

# Where the PNGs land (also the artifact the workflow uploads).
output_directory("./fastlane/screenshots")

# Start clean so a re-run never mixes old and new frames.
clear_previous_screenshots(true)

# One simulator at a time keeps memory low and network loads deterministic.
concurrent_simulators(false)

# Surface a broken capture immediately instead of half a set.
stop_after_first_error(true)

# The app pulls real content over the network; give slow first renders room.
number_of_retries(2)
